<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- Tela Principal do App (Músicas) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_above="@+id/miniPlayerContainer">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Músicas"
                android:textSize="24sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_centerVertical="true"/>
                
            <ProgressBar
                android:id="@+id/loadingIndicator"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_toStartOf="@id/btnSelectFolder"
                android:layout_centerVertical="true"
                android:layout_marginEnd="16dp"
                android:indeterminateTint="#1DB954"
                android:visibility="gone" />
                
            <ImageButton
                android:id="@+id/btnSelectFolder"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:src="@drawable/ic_folder"
                android:scaleType="centerInside"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:tint="#1DB954"
                android:contentDescription="Selecionar Pasta"/>
        </RelativeLayout>

        <ListView
            android:id="@+id/listView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="#333333"
            android:dividerHeight="1dp"/>
    </LinearLayout>

    <!-- Mini-Player (Fixo na parte inferior) -->
    <LinearLayout
        android:id="@+id/miniPlayerContainer"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="#1E1E1E"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="4dp"
        android:elevation="8dp">

        <ImageView
            android:id="@+id/miniAlbumArt"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_music_note"
            android:scaleType="centerCrop"
            android:background="#2A2A2A"
            android:padding="8dp"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvMiniSongTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nenhuma música"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvMiniSongArtist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Artista"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:singleLine="true"
                android:ellipsize="end"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnMiniPlayPause"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_play"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"/>

        <ImageButton
            android:id="@+id/btnMiniNext"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_skip_next"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"/>
    </LinearLayout>

    <!-- Tela do Player em Tela Cheia (Escondida por Padrão) -->
    <LinearLayout
        android:id="@+id/fullPlayerContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#121212"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">
        
        <!-- Botão de fechar (seta para baixo) -->
        <ImageButton
            android:id="@+id/btnClosePlayer"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_chevron_down"
            android:scaleType="centerInside"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"/>

        <!-- Capa do Álbum (grande) Quadrada 1:1 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp">
            
            <ImageView
                android:id="@+id/fullAlbumArt"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_music_note"
                android:scaleType="centerCrop"
                android:background="#1A1A1A"
                android:padding="40dp"/>
        </FrameLayout>

        <!-- Título e Artista -->
        <TextView
            android:id="@+id/tvFullSongTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nenhuma música tocando"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvFullSongArtist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Artista Desconhecido"
            android:textColor="#B3B3B3"
            android:textSize="16sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginBottom="20dp"/>

        <!-- SeekBar com tempos -->
        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressTint="#1DB954"
            android:thumbTint="#1DB954"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0:00"
                android:textColor="#B3B3B3"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="#B3B3B3"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Controles Principais -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnShuffle"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:src="@drawable/ic_shuffle"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"/>

            <ImageButton
                android:id="@+id/btnPrev"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:src="@drawable/ic_skip_previous"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"/>

            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:src="@drawable/ic_play"
                android:scaleType="centerInside"
                android:padding="12dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"/>

            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:src="@drawable/ic_skip_next"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"/>

            <ImageButton
                android:id="@+id/btnRepeat"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:src="@drawable/ic_repeat"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>
        
        <!-- Controles Inferiores Adicionais (Letras, Dispositivos, Fila) -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:paddingBottom="24dp">
            
            <ImageButton
                android:id="@+id/btnQueue"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:src="@drawable/ic_queue_music"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"/>
        </RelativeLayout>
    </LinearLayout>

    <!-- Folha Deslizante da Fila (BottomSheet) -->
    <LinearLayout
        android:id="@+id/bottomSheetQueue"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#1E1E1E"
        android:visibility="gone"
        android:padding="16dp"
        android:clickable="true"
        android:focusable="true">
        
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fila de Reprodução"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_centerVertical="true"/>
                
            <ImageButton
                android:id="@+id/btnCloseQueue"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:src="@drawable/ic_chevron_down"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:tint="#FFFFFF"/>
        </RelativeLayout>
        
        <ListView
            android:id="@+id/queueListView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@null"
            android:dividerHeight="0dp"/>
            
    </LinearLayout>

</RelativeLayout>
